{
  "name": "homemade-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm-run-all --parallel dev:next dev:amplify",
    "dev:next": "next dev --turbopack",
    "dev:amplify": "amplify dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "next": "15.4.1",
    "@tanstack/react-query": "^5.59.16",
    "@tanstack/react-query-devtools": "^5.59.16",
    "zustand": "^4.5.2",
    "@headlessui/react": "^2.1.1",
    "recharts": "^2.12.7",
    "maplibre-gl": "^3.6.2",
    "ngeohash": "^0.6.3",
    "@aws-sdk/client-dynamodb": "^3.540.0",
    "@aws-sdk/lib-dynamodb": "^3.540.0",
    "@aws-sdk/client-sns": "^3.540.0",
    "@aws-sdk/client-ses": "^3.540.0",
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "stripe": "^14.20.0",
    "zod": "^3.23.8",
    "ulid": "^2.3.0",
    "date-fns": "^3.6.0",
    "react-hot-toast": "^2.4.1",
    "lucide-react": "^0.460.0"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@tailwindcss/postcss": "^4",
    "tailwindcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "15.4.1",
    "@eslint/eslintrc": "^3",
    "npm-run-all": "^4.1.5",
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "tsx": "^4.19.2",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "@types/ngeohash": "^0.6.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
